# Configuración del Sistema de Seguimiento Financiero
# Copiar este archivo a .env y completar los valores

# Clave secreta para JWT (generar una clave segura)
SECRET_KEY=tu_clave_secreta_muy_segura_cambiar_en_produccion

# Algoritmo de firma JWT
ALGORITHM=HS256

# Tiempo de expiración del token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=30

# URL de la base de datos SQLite
DATABASE_URL=sqlite:///./financial_tracker.db

# Configuración de correo (opcional para alertas críticas)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_de_aplicacion

# Configuración de umbrales de alertas (porcentaje)
ALERT_THRESHOLD_WARNING=3.0
ALERT_THRESHOLD_CRITICAL=7.0
