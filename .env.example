# ============================================================================
# Configuración del Sistema de Seguimiento Financiero
# ============================================================================
#
# INSTRUCCIONES DE USO:
# 1. Copiar este archivo: cp .env.example .env
# 2. Editar .env con tus valores
# 3. NUNCA commitear .env a git (ya está en .gitignore)
#
# ============================================================================

# ============================================================================
# SEGURIDAD Y AUTENTICACIÓN JWT
# ============================================================================

# SECRET_KEY: Clave secreta para firmar tokens JWT
#
# IMPORTANTE: Esta clave DEBE ser única y segura en producción
#
# Generar una clave segura (ejecutar en terminal):
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
#   o
#   openssl rand -hex 32
#
# Para desarrollo puedes usar este valor temporal, pero CÁMBIALO en producción:
SECRET_KEY=dev-secret-key-CHANGE-IN-PRODUCTION-use-random-string

# Algoritmo de firma JWT (HS256 es el estándar recomendado)
ALGORITHM=HS256

# Tiempo de expiración del token de acceso en minutos
# Valores recomendados:
#   - Desarrollo: 30-60 minutos
#   - Producción: 15-30 minutos (mayor seguridad)
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ============================================================================
# BASE DE DATOS
# ============================================================================

# URL de conexión a la base de datos
#
# SQLite (desarrollo - valor por defecto):
DATABASE_URL=sqlite:///./financial_tracker.db
#
# PostgreSQL (producción - ejemplo):
# DATABASE_URL=postgresql://usuario:password@localhost:5432/financial_tracker
#
# MySQL (producción - ejemplo):
# DATABASE_URL=mysql+pymysql://usuario:password@localhost:3306/financial_tracker

# ============================================================================
# NOTIFICACIONES POR EMAIL (OPCIONAL)
# ============================================================================

# Configuración SMTP para enviar alertas críticas por correo
# Si no necesitas notificaciones por email, puedes dejar estos valores por defecto
#
# Para Gmail:
# 1. Habilitar "Verificación en dos pasos" en tu cuenta
# 2. Generar "Contraseña de aplicación" en https://myaccount.google.com/apppasswords
# 3. Usar esa contraseña en SMTP_PASSWORD (no tu contraseña de Gmail)
#
# Nota: Las notificaciones por email no están implementadas en v1.0
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=tu_password_de_aplicacion_de_16_caracteres

# ============================================================================
# CONFIGURACIÓN DE ALERTAS
# ============================================================================

# Umbral de alerta WARNING (variación porcentual respecto a la predicción)
# Ejemplo: 3.0 = alerta cuando el precio varía ±3% respecto al precio predicho
ALERT_THRESHOLD_WARNING=3.0

# Umbral de alerta CRITICAL (variación porcentual respecto a la predicción)
# Ejemplo: 7.0 = alerta crítica cuando el precio varía ±7% respecto al precio predicho
ALERT_THRESHOLD_CRITICAL=7.0

# ============================================================================
# CONFIGURACIÓN AVANZADA (OPCIONAL)
# ============================================================================

# Puerto del servidor backend (por defecto: 8000)
# PORT=8000

# Modo de desarrollo (activa logs detallados)
# DEBUG=true

# Orígenes CORS permitidos (separados por coma)
# CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# Tiempo de caché para datos de mercado (segundos)
# CACHE_MARKET_DATA_TTL=300

# Tiempo de caché para análisis de sentimiento (segundos)
# CACHE_SENTIMENT_TTL=3600
